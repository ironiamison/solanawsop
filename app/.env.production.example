# Production — copy to .env.production before docker compose up

NEXT_PUBLIC_APP_URL=https://solanawsop.com

# Game server (Railway / Render / VPS) — required for live demo table on Vercel.
# Deploy: cd app && npm run start:socket  (or Dockerfile.socket on Railway)
# NEXT_PUBLIC_SOCKET_URL=https://your-socket-service.up.railway.app
# ALLOWED_ORIGINS=https://solanawsop.com,https://www.solanawsop.com
NEXT_PUBLIC_TOKEN_SYMBOL=$SWSOP
# Required for real $SWSOP cash games — pump.fun mint address
NEXT_PUBLIC_SWSOP_MINT=CdHs25efdXYnSwFbEynBdqgmECe1tARoNpLwzjN2pump
NEXT_PUBLIC_PUMP_FUN_URL=https://pump.fun/coin/CdHs25efdXYnSwFbEynBdqgmECe1tARoNpLwzjN2pump
NEXT_PUBLIC_TOKEN_NAME=SolanaWSOP
NEXT_PUBLIC_BRAND_NAME=SolanaWSOP
# mainnet-beta hides the cluster badge in the header
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
HELIUS_API_KEY=
HELIUS_API_BASE=https://api-mainnet.helius-rpc.com/v0
NEXT_PUBLIC_MAINNET_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Keep devnet URL if you still run dev tables from the same build
NEXT_PUBLIC_RPC_URL=https://beta.helius-rpc.com/?api-key=YOUR_KEY
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
# Or SQLite on a persistent volume (not recommended on Vercel serverless):
# DATABASE_URL="file:./prisma/prod.db"

# Demo multi-player state (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# After anchor deploy:
# NEXT_PUBLIC_PRIVATE_TABLES_ENABLED=true
